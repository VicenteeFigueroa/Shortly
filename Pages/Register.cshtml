@page
@model Shortly.Pages.RegisterModel
@{
    ViewData["Title"] = "Register";
}

<div class="aero-info-panel mb-3">
    <div>
        <svg class="aero-info-icon" viewBox="0 0 48 48" fill="none">
            <rect width="48" height="48" rx="6" fill="#EAF2FC"/>
            <circle cx="24" cy="16" r="7" stroke="#3A9B35" stroke-width="2.5" fill="none"/>
            <path d="M12 38c0-6.63 5.37-12 12-12s12 5.37 12 12" stroke="#3A9B35" stroke-width="2.5" fill="none" stroke-linecap="round"/>
            <path d="M36 18l4 0M38 16l0 4" stroke="#3A9B35" stroke-width="2.5" stroke-linecap="round"/>
        </svg>
    </div>
    <div class="aero-info-text">
        <h2>Create New Account</h2>
        <p>Register a new account to start shortening and tracking your URLs.</p>
    </div>
</div>

<hr class="aero-separator" />

@if (!ModelState.IsValid)
{
    <div class="validation-summary-errors" asp-validation-summary="All"></div>
}

<form method="post">
    <div class="aero-group" style="position: relative; max-width: 400px;">
        <span class="aero-group-title">Account Information</span>

        <div class="aero-form-row">
            <label asp-for="Input.Email" class="aero-form-label">E-mail:</label>
            <div class="aero-form-field">
                <input asp-for="Input.Email" class="aero-input" placeholder="user@example.com" />
                <span asp-validation-for="Input.Email" class="field-validation-error"></span>
            </div>
        </div>

        <div class="aero-form-row">
            <label asp-for="Input.Password" class="aero-form-label">Password:</label>
            <div class="aero-form-field">
                <input asp-for="Input.Password" class="aero-input" type="password" />
                <span asp-validation-for="Input.Password" class="field-validation-error"></span>
            </div>
        </div>
    </div>

    <hr class="aero-separator" />

    <div style="display: flex; gap: 8px; justify-content: flex-end; align-items: center;">
        <span style="font-size: 12px; margin-right: auto;">Already have an account? <a asp-page="/Login">Log In</a></span>
        <button type="submit" class="aero-btn aero-btn-primary">Register</button>
        <a asp-page="/Index" class="aero-btn" style="text-decoration: none;">Cancel</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
