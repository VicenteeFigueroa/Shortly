<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Shortly</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <div class="aero-window">
        <!-- Title Bar -->
        <div class="aero-titlebar">
            <span class="aero-titlebar-text">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path>
                    <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path>
                </svg>
                Shortly — URL Shortener
            </span>
            <div class="aero-titlebar-buttons">
                <span class="aero-btn-chrome">─</span>
                <span class="aero-btn-chrome">☐</span>
                <span class="aero-btn-chrome close">✕</span>
            </div>
        </div>

        <!-- Toolbar / Navigation -->
        <div class="aero-toolbar">
            <a class="aero-nav-item" asp-page="/Index">Home</a>
            @if (User.Identity?.IsAuthenticated == true)
            {
                <span class="aero-nav-separator"></span>
                <a class="aero-nav-item active" asp-page="/Index">Dashboard</a>
                <span class="aero-nav-separator"></span>
                <form asp-page="/Logout" method="post" style="display: inline; margin: 0;">
                    <button type="submit" class="aero-nav-item" style="border: 1px solid transparent; background: transparent; cursor: pointer; font-family: 'Segoe UI', sans-serif; font-size: 12px;">
                        Sign out (@User.Identity.Name)
                    </button>
                </form>
            }
            else
            {
                <span class="aero-nav-separator"></span>
                <a class="aero-nav-item" asp-page="/Login">Log In</a>
                <a class="aero-nav-item" asp-page="/Register">Register</a>
            }
        </div>

        <!-- Body -->
        <div class="aero-body">
            @RenderBody()
        </div>

        <!-- Status Bar -->
        <div class="aero-statusbar">
            &copy; @DateTime.Now.Year Shortly — Built with ASP.NET Core
        </div>
    </div>

    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
