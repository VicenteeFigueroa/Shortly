@page
@model IndexModel
@{
    ViewData["Title"] = "Home";
}

@if (!User.Identity?.IsAuthenticated ?? true)
{
    <div class="aero-info-panel mb-3">
        <div>
            <svg class="aero-info-icon" viewBox="0 0 48 48" fill="none">
                <rect width="48" height="48" rx="6" fill="#EAF2FC"/>
                <path d="M16 26a8 8 0 0 0 12.06.86l4.8-4.8a8 8 0 0 0-11.31-11.31L19 13.5" stroke="#4580C4" stroke-width="2.5" stroke-linecap="round"/>
                <path d="M32 22a8 8 0 0 0-12.06-.86l-4.8 4.8a8 8 0 0 0 11.31 11.31L29 34.5" stroke="#4580C4" stroke-width="2.5" stroke-linecap="round"/>
            </svg>
        </div>
        <div class="aero-info-text">
            <h2>Welcome to Shortly</h2>
            <p>
                Shortly is a simple and fast URL shortener. Create short, memorable
                links from long URLs and track how many times they've been clicked.
            </p>
            <p style="margin-top: 8px;">
                To get started, create an account or log in with an existing one.
            </p>
        </div>
    </div>

    <hr class="aero-separator" />

    <div style="display: flex; gap: 8px; justify-content: flex-end;">
        <a asp-page="/Register" class="aero-btn aero-btn-primary" style="text-decoration: none;">Register</a>
        <a asp-page="/Login" class="aero-btn" style="text-decoration: none;">Log In</a>
    </div>
}
else
{
    <div class="aero-group mb-4" style="position: relative;">
        <span class="aero-group-title">Create New Short Link</span>

        @if (!ModelState.IsValid)
        {
            <div class="validation-summary-errors" asp-validation-summary="All"></div>
        }

        <form method="post">
            <div class="aero-form-row">
                <label asp-for="Input.Url" class="aero-form-label">URL:</label>
                <div class="aero-form-field">
                    <input asp-for="Input.Url" class="aero-input" placeholder="https://very-long-url.com/path" />
                </div>
                <button type="submit" class="aero-btn aero-btn-primary">Shorten</button>
            </div>
            <span asp-validation-for="Input.Url" class="field-validation-error" style="margin-left: 80px;"></span>
        </form>
    </div>

    <div class="aero-group" style="position: relative;">
        <span class="aero-group-title">Your Links</span>

        @if (Model.Links.Any())
        {
            <div style="overflow-x: auto;">
                <table class="aero-listview">
                    <thead>
                        <tr>
                            <th style="width: 40%;">Original URL</th>
                            <th style="width: 25%;">Short URL</th>
                            <th style="width: 10%;">Clicks</th>
                            <th style="width: 25%;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var link in Model.Links)
                        {
                            var fullShortUrl = $"{Request.Scheme}://{Request.Host}/{link.ShortUrl}";
                            <tr>
                                <td>
                                    <div style="max-width: 260px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;" title="@link.Url">
                                        <a href="@link.Url" target="_blank">@link.Url</a>
                                    </div>
                                </td>
                                <td class="short-url-cell">
                                    <a href="@fullShortUrl" target="_blank">@link.ShortUrl</a>
                                </td>
                                <td class="clicks-cell">@link.Clicks</td>
                                <td>
                                    <button class="aero-btn" onclick="navigator.clipboard.writeText('@fullShortUrl'); alert('Link copied to clipboard!');">
                                        📋 Copy
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="empty-state">
                <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path>
                    <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path>
                </svg>
                <p>You haven't created any links yet. Use the form above to shorten your first URL.</p>
            </div>
        }
    </div>
}
